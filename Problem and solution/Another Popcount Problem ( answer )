#include <iostream>

void solve() {
    long long n, k;
    std::cin >> n >> k;
    
    long long total_popcount = 0;
    long long current_bit_value = 1;
    
    while (n > 0) {
        // Total value if we set this bit in all k numbers
        long long max_take_value = k * current_bit_value;
        
        if (n >= max_take_value) {
            // We can afford to set this bit in all k elements
            total_popcount += k;
            n -= max_take_value;
        } else {
            // We can only afford a partial amount of this bit
            total_popcount += (n / current_bit_value);
            break; // No need to continue as higher bits cost even more
        }
        
        // Move to the next bit position (2^j)
        // Prevent potential overflow if current_bit_value exceeds n
        if (current_bit_value > n) {
            break;
        }
        current_bit_value *= 2;
    }
    
    std::cout << total_popcount << "\n";
}

int main() {
    std::ios_base::sync_with_stdio(false);
    std::cin.tie(NULL);
    
    int t;
    std::cin >> t;
    while (t--) {
        solve();
    }
    
    return 0;
}
